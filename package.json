    "autoprefixer": "10.4.20",
    "framer-motion": "11.11.17",
    "next": "14.2.18",
    "postcss": "8.4.49",
    "posthog-js": "1.181.0",
    "prisma": "5.22.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "reactflow": "^11.11.4",
    "tailwindcss": "3.4.14",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  },
  "devDependencies": {
    "@types/node": "20.17.6",
