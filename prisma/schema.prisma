// Multi-vector rewrite: each tool now has three halfvec(3072) embeddings — name, tagline, description — so a query
// can match any field directly instead of fighting a single diluted blob. halfvec stores in 2 bytes per dim, so 3×3072
// is ~18KB/tool — cheap compared to the recall lift vs the old 768-d Matryoshka cut. HNSW indexes are created per
// column (one per field) at seed time. A weighted tsvector on AiTool feeds the lexical leg of RRF.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector")]
}

model AiTool {
  id               String         @id @default(cuid())
  slug             String         @unique
  name             String
  tagline          String
  description      String
  website          String
  pricing          PricingType
  isOpenSource     Boolean        @default(false)
  isPrivacyFocused Boolean        @default(false)
  // True when the row was auto-inserted from a Gemini live-discovery response, false when seeded or hand-curated.
  isAutoDiscovered Boolean        @default(false)
  platforms        String[]
  trustScore       Float          @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  categoryId       String
  category         Category       @relation(fields: [categoryId], references: [id])
  tags             Tag[]
  embedding        ToolEmbedding?

  @@index([categoryId])
}

model ToolEmbedding {
  id             String                       @id @default(cuid())
  toolId         String                       @unique
  tool           AiTool                       @relation(fields: [toolId], references: [id], onDelete: Cascade)
  // halfvec stores half-precision floats; HNSW indexes halfvec up to 4000 dim (`vector` only up to 2000).
  nameVec        Unsupported("halfvec(3072)")
  taglineVec     Unsupported("halfvec(3072)")
  descriptionVec Unsupported("halfvec(3072)")
}

model Category {
  id    String   @id @default(cuid())
  slug  String   @unique
  name  String
  icon  String
  tools AiTool[]
}

model Tag {
  id    String   @id @default(cuid())
  slug  String   @unique
  name  String
  tools AiTool[]
}

enum PricingType {
  FREE
  FREEMIUM
  PAID
  OPEN_SOURCE
}

// Expansion P1 decision: Workflows are user-authored tool chains. Nodes carry their own toolDomain so the chain renders even when a node points to a Gemini-discovered tool not in our DB. Cascade delete on workflowId.
// Edge expansion: WorkflowEdge stores arbitrary node-to-node connections so the canvas works like n8n
// (any topology, not just a linear chain). WorkflowNode.order is still maintained for the legacy linear
// renderer and as a stable presentation order when the graph has no custom edges.
model Workflow {
  id          String         @id @default(cuid())
  title       String
  description String?
  isPublic    Boolean        @default(false)
  authorId    String
  authorName  String
  authorImage String?
  nodes       WorkflowNode[]
  edges       WorkflowEdge[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([authorId])
  @@index([isPublic])
  @@index([createdAt])
}

model WorkflowNode {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  order      Int
  toolName   String
  toolSlug   String?
  toolDomain String?
  useCase    String
  positionX  Float    @default(0)
  positionY  Float    @default(0)

  @@index([workflowId])
}

model WorkflowEdge {
  id           String   @id @default(cuid())
  workflowId   String
  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  // sourceNodeId / targetNodeId reference WorkflowNode.id values. NOT FK-constrained because
  // we recreate (deleteMany + createMany) nodes on save — the API layer validates that both
  // IDs refer to nodes inside the same workflow before insert.
  sourceNodeId String
  targetNodeId String

  @@index([workflowId])
  @@unique([workflowId, sourceNodeId, targetNodeId])
}
